# ============================================================
# Telegram Lead Capture Pipeline — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See docs/SETUP_GUIDE.md for where to get each value.
# See docs/ENV_REFERENCE.md for detailed descriptions.
# ============================================================

# --- REQUIRED: API Keys ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get from console.anthropic.com > API Keys
CLAUDE_API_KEY=your_claude_api_key_here

# Get from GHL > Settings > Integrations > Private Integrations
GHL_API_KEY=your_ghl_api_key_here

# Get from GHL > Settings > Business Profile (or from the URL)
GHL_LOCATION_ID=your_ghl_location_id_here

# --- REQUIRED: Security ---
# Any random string — must match what you use in the setWebhook call
WEBHOOK_SECRET=your_webhook_secret_here

# --- OPTIONAL: Admin Access ---
# Set a fixed key for admin endpoints, or leave blank to auto-generate on each boot
ADMIN_API_KEY=

# --- OPTIONAL: Claude AI Settings ---
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4000
CLAUDE_TIMEOUT=60

# --- OPTIONAL: Processing Settings ---
# Minimum confidence (0.0-1.0) to accept an extraction. Default 0.25.
MIN_CONFIDENCE_THRESHOLD=0.25

# Hours to remember processed images (dedup window). Default 24.
IMAGE_FINGERPRINT_TTL_HOURS=24

# --- OPTIONAL: Application Settings ---
LOG_LEVEL=INFO
ENV=development
DEBUG=false

# --- OPTIONAL: Database ---
# SQLite works out of the box. For persistent storage, use PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./telegram_ghl.db

# --- OPTIONAL: Monitoring ---
# Redis (not required)
REDIS_URL=

# Sentry error tracking (not required)
SENTRY_DSN=
